#include "xil_printf.h"
#include "xparameters.h"
#include "xstatus.h"
#include "xttcps.h"
#include "xtmrctr.h"

#define PCLK_FREQ_HZ XPAR_XTTCPS_0_CLOCK_HZ /* Input freq */
#define TMRCTR_DEVICE_ID        XPAR_TMRCTR_0_DEVICE_ID

#define TABLE_OFFSET 9

#define PWM_PERIOD              500    /* PWM period in (500 ms) */
#define TMRCTR_0                0            /* Timer 0 ID */
#define TMRCTR_1                1            /* Timer 1 ID */
#define CYCLE_PER_DUTYCYCLE     10           /* Clock cycles per duty cycle */
#define MAX_DUTYCYCLE           100          /* Max duty cycle */
#define DUTYCYCLE_DIVISOR       4            /* Duty cycle Divisor */


XTmrCtr TimerCounterInst;  /* The instance of the Timer Counter */



int main(void) {
	int Status;

	Status = XTmrCtr_Initialize(&TimerCounterInst, TMRCTR_DEVICE_ID);
	if (Status != XST_SUCCESS) {
		return XST_FAILURE;
	}

	Status = XTmrCtr_SelfTest(&TimerCounterInst, TMRCTR_0);
	if (Status != XST_SUCCESS) {
		return XST_FAILURE;
	}

	int Div = DUTYCYCLE_DIVISOR;
	XTmrCtr_PwmDisable(&TimerCounterInst);

	/* Configure PWM */
	int Period = PWM_PERIOD;
	int HighTime = PWM_PERIOD / Div--;
	int DutyCycle = XTmrCtr_PwmConfigure(&TimerCounterInst, Period,
			HighTime);
	if (Status != XST_SUCCESS) {
		Status = XST_FAILURE;

	}

	xil_printf("PWM Configured for Duty Cycle = %d\r\n", DutyCycle);

	XTmrCtr_PwmEnable(&TimerCounterInst);

	return XST_SUCCESS;
}


